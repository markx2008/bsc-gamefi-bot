generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int                 @id @default(autoincrement())
  walletAddress  String              @unique
  balanceUsdt    Decimal             @default(0) @db.Decimal(36, 18)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  transactions   Transaction[]
  withdrawals    WithdrawalRequest[]
  gameRounds     GameRound[]
  earnPositions  EarnPosition[]
  fairnessCommitment GameFairnessCommitment?
}

model Transaction {
  id          Int               @id @default(autoincrement())
  userId      Int
  user        User              @relation(fields: [userId], references: [id])
  type        TransactionType
  amount      Decimal           @db.Decimal(36, 18)
  txHash      String?           @unique
  status      TransactionStatus @default(PENDING)
  blockNumber BigInt?
  createdAt   DateTime          @default(now())
}

model PendingDeposit {
  id            Int                  @id @default(autoincrement())
  walletAddress String
  amount        Decimal              @db.Decimal(36, 18)
  txHash        String               @unique
  blockNumber   BigInt?
  status        PendingDepositStatus @default(PENDING)
  createdAt     DateTime             @default(now())
  resolvedAt    DateTime?
}

model ChainCheckpoint {
  id          String   @id
  blockNumber BigInt
  updatedAt   DateTime @updatedAt
}

model WithdrawalRequest {
  id            Int              @id @default(autoincrement())
  userId        Int
  user          User             @relation(fields: [userId], references: [id])
  amount        Decimal          @db.Decimal(36, 18)
  walletAddress String
  status        WithdrawalStatus @default(PENDING)
  txHash        String?          @unique
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model GameRound {
  id                Int                   @id @default(autoincrement())
  userId            Int
  user              User                  @relation(fields: [userId], references: [id])
  game              GameKey
  betAmount         Decimal               @db.Decimal(36, 18)
  playerChoice      String
  outcome           String
  result            GameRoundResult
  payoutAmount      Decimal               @db.Decimal(36, 18)
  userBalanceDelta  Decimal               @db.Decimal(36, 18)
  houseProfit       Decimal               @db.Decimal(36, 18)
  platformCut       Decimal               @default(0) @db.Decimal(36, 18)
  gameBankrollDelta Decimal               @default(0) @db.Decimal(36, 18)
  bonusPoolCut      Decimal               @default(0) @db.Decimal(36, 18)
  serverSeedHash    String?
  serverSeed        String?
  clientSeed        String?
  nonce             Int?
  randomDigest      String?
  createdAt         DateTime              @default(now())
  ledgerEntries     PlatformLedgerEntry[]

  @@index([userId, createdAt])
  @@index([game, createdAt])
  @@index([serverSeedHash])
}

model GameFairnessCommitment {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  user           User     @relation(fields: [userId], references: [id])
  serverSeed     String
  serverSeedHash String
  nonce          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model EarnPosition {
  id                    Int                @id @default(autoincrement())
  userId                Int
  user                  User               @relation(fields: [userId], references: [id])
  principal             Decimal            @db.Decimal(36, 18)
  status                EarnPositionStatus @default(ACTIVE)
  lockedAt              DateTime           @default(now())
  unlockAt              DateTime
  redeemedAt            DateTime?
  externalYieldAmount   Decimal            @default(0) @db.Decimal(36, 18)
  bonusPoolRewardAmount Decimal            @default(0) @db.Decimal(36, 18)
  rewardAmount          Decimal            @default(0) @db.Decimal(36, 18)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([userId, status, unlockAt])
  @@index([status, unlockAt])
}

model PlatformLedgerEntry {
  id        Int                      @id @default(autoincrement())
  pool      PlatformPool
  source    PlatformLedgerSourceType
  sourceId  Int?
  gameRoundId Int?
  amount    Decimal                  @db.Decimal(36, 18)
  note      String?
  createdAt DateTime                 @default(now())
  gameRound GameRound?               @relation(fields: [gameRoundId], references: [id])

  @@index([pool, createdAt])
  @@index([source, sourceId])
  @@index([gameRoundId])
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  REWARD
  GAME_LOSS
  GAME_WIN
  EARN_LOCK
  EARN_REDEEM
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REJECTED
}

enum PendingDepositStatus {
  PENDING
  RESOLVED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  SENT
  FAILED
}

enum GameKey {
  COIN_FLIP
  DICE
  LUCKY_SPIN
}

enum GameRoundResult {
  PLAYER_WIN
  HOUSE_WIN
}

enum PlatformPool {
  GAME_BANKROLL
  PLATFORM_REVENUE
  EARN_BONUS_POOL
}

enum PlatformLedgerSourceType {
  GAME_ROUND
  EARN_EXTERNAL_YIELD
  EARN_REWARD_RELEASE
  ADMIN_ADJUSTMENT
}

enum EarnPositionStatus {
  ACTIVE
  REDEEMED
}
