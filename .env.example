# --- 區塊鏈設定 ---
# BSC 節點地址 (可用 QuickNode, Ankr 或官方節點)
RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
# USDT 代幣合約地址 (BSC Testnet)
USDT_ADDRESS=0x...
# VaultManager 合約地址
VAULT_ADDRESS=0x...
# StakingVault 合約地址
STAKING_VAULT_ADDRESS=0x...
# 平台收益錢包；未設定時 deploy script 會使用部署者地址
PLATFORM_TREASURY=0x...
# 管理員熱錢包私鑰 (用於部署、分紅與提現)
ADMIN_PRIVATE_KEY=your_private_key_here
# Token decimals；MockUSDT 使用 18
USDT_DECIMALS=18
# 首次啟動 listener 可指定補掃起始區塊；未設定時從目前區塊開始
LISTENER_START_BLOCK=
LISTENER_BLOCK_CHUNK_SIZE=2000

# --- 資料庫設定 ---
# Docker Compose 會覆蓋 app container 內的 DATABASE_URL，指向 compose 裡的 postgres service。
# 手動在本機執行 npm run db:init / npm run dev 時，使用下面這個 DATABASE_URL。
DATABASE_URL=postgresql://user:password@localhost:5432/gamefi

# --- Telegram 設定 ---
TELEGRAM_BOT_TOKEN=your_bot_token
# 您自己的 Telegram ID (用於管理員權限驗證)
ADMIN_TG_ID=12345678

# --- API 設定 ---
PORT=3001
JWT_SECRET=some_random_secret_for_auth
# production 預設關閉 dev login；若要在 staging 明確開啟，設為 true
WEB_MVP_ENABLE_DEV_LOGIN=false

# --- Docker Compose host ports ---
# 如果本機 3000 / 3001 / 15432 被占用，可以改這裡；container 內部 port 不變。
WEB_HOST_PORT=3000
LISTENER_HOST_PORT=3001
POSTGRES_HOST_PORT=15432
