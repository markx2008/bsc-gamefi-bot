# --- 區塊鏈設定 ---
# BSC 節點地址 (可用 QuickNode, Ankr 或官方節點)
RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
# USDT 代幣合約地址 (BSC Testnet)
USDT_ADDRESS=0x...
# VaultManager 合約地址
VAULT_ADDRESS=0x...
# 管理員熱錢包私鑰 (用於執行提現)
ADMIN_PRIVATE_KEY=your_private_key_here

# --- 資料庫設定 (Zeabur 會自動提供或手動填入) ---
DATABASE_URL=postgresql://user:password@localhost:5432/gamefi

# --- Telegram 設定 ---
TELEGRAM_BOT_TOKEN=your_bot_token
# 您自己的 Telegram ID (用於管理員權限驗證)
ADMIN_TG_ID=12345678

# --- API 設定 ---
PORT=3001
JWT_SECRET=some_random_secret_for_auth
